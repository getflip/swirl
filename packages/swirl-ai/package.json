{
  "name": "@getflip/swirl-ai",
  "version": "0.459.2",
  "description": "Swirl Design System AI package with artifacts for AI agents",
  "author": "Flip GmbH",
  "repository": "https://github.com/getflip/swirl",
  "license": "SEE LICENSE IN LICENSE.md",
  "bugs": {
    "url": "https://github.com/getflip/swirl/issues"
  },
  "type": "module",
  "bin": {
    "swirl-ai": "./dist/mcp/mcp.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    "./manifest": "./dist/custom-elements.manifest.json",
    "./agent-index": "./dist/agent/components-index.json"
  },
  "scripts": {
    "build": "tsx scripts/build.ts && tsup",
    "build:artifacts": "tsx scripts/build.ts",
    "build:mcp": "tsup",
    "dev": "tsx scripts/mcp.ts",
    "lint": "tsc --noEmit"
  },
  "tsup": {
    "entry": [
      "scripts/mcp.ts"
    ],
    "format": [
      "esm"
    ],
    "target": "node18",
    "outDir": "dist/mcp",
    "clean": false,
    "banner": {
      "js": "#!/usr/bin/env node"
    }
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.27.1",
    "zod": "3.24.0"
  },
  "devDependencies": {
    "@getflip/swirl-components": "0.459.2",
    "@types/node": "25.3.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "5.9.3"
  }
}
