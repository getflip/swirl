{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": ".",
    "outDir": "dist",
    "types": ["node"],
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noImplicitAny": true,
    "skipLibCheck": true
  },
  "include": [
    "scripts/**/*",
    "lib/augment-manifest.ts",
    "lib/parse-mdx.ts",
    "lib/parse-tsx.ts",
    "lib/types.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
