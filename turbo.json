{
  "$schema": "https://turborepo.org/schema.json",
  "globalPassThroughEnv": [
    "ALGOLIA_SEARCH_ADMIN_KEY",
    "GITLAB_ACCESS_TOKEN",
    "GITLAB_FLIP_REPO_ID",
    "REFERENCE_BRANCH",
    "NEXT_PUBLIC_ALGOLIA_APP_ID",
    "NEXT_PUBLIC_ALGOLIA_SEARCH_API_KEY",
    "NEXT_PUBLIC_DEPLOYMENT_STAGE",
    "SITE_PASSWORD"
  ],
  "tasks": {
    "build": {
      "outputs": [
        "dist/**",
        "build/**",
        "loader/**",
        "storybook-static/**",
        "stencil-generated/**",
        "lib/stencil-generated/**",
        ".next/**"
      ],
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": []
    },
    "test:coverage": {
      "dependsOn": []
    },
    "lint": {
      "outputs": [".eslintcache"]
    },
    "dev": {
      "cache": false,
      "outputs": [".next/**"],
      "dependsOn": ["@getflip/swirl-tokens#build", "@getflip/swirl-icons#build"]
    },
    "clean": {
      "cache": false
    },
    "gulp": {
      "outputs": ["dist/**"]
    },
    "prebuild": {
      "cache": false,
      "outputs": [
        "specs/**",
        "problem.yml",
        "shared.yml",
        "components.json",
        "src/lib/navigation/src/data/apiDocs.data.ts",
        "src/lib/navigation/src/data/apiSpecs.data.ts",
        "src/lib/navigation/src/data/apiEndpoints.data.ts"
      ]
    },
    "build:swirl-docs": {
      "cache": false,
      "outputs": [".next/**"],
      "dependsOn": [
        "prebuild",
        "^stencil:build",
        "@getflip/swirl-components-react#build"
      ]
    },
    "@getflip/swirl-ai#build": {
      "dependsOn": ["^build", "@getflip/swirl-components#build"]
    },
    "stencil:build": {
      "outputs": ["dist/**", "components.json"],
      "dependsOn": ["@getflip/swirl-tokens#build"]
    }
  }
}
